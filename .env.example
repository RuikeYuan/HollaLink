# Copy this file to .env and fill in real values. Never commit .env.

# ---- LLM provider ----
# Which provider the backend uses for chat + embeddings: gemini | openai | groq
LLM_PROVIDER=gemini

GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini

GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# ---- Database ----
DATABASE_URL=postgresql+psycopg2://dutch_app:dutch_app@localhost:5432/dutch_business_ai
POSTGRES_USER=dutch_app
POSTGRES_PASSWORD=dutch_app
POSTGRES_DB=dutch_business_ai

# ---- Vector store ----
CHROMA_PERSIST_DIR=./chroma_data

# ---- Admin ----
# Simple shared-secret admin token (sent as X-Admin-Token header). Change this.
ADMIN_TOKEN=change-me-admin-token

# ---- API ----
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_PER_MINUTE=30

# ---- Frontend ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
